# .env.example — copy to .env.local (dev) or set in your deployment env (prod).
# Sensible defaults where possible; REQUIRED items marked below.

# ─── model access ───────────────────────────────────────────────────────────
# REQUIRED for any live-mode run. Also needed by the eval harness.
ANTHROPIC_API_KEY=

# ─── auth cookie encryption ─────────────────────────────────────────────────
# REQUIRED in production. AES-256-GCM encrypts the bi_auth cookie that
# carries OAuth state + tokens across Vercel's stateless function instances.
# Any 32+ character random string. Generate with:  openssl rand -base64 32
# Not needed locally — dev persists auth to a gitignored .auth-cache.json.
AUTH_SECRET=

# ─── MCP server config ──────────────────────────────────────────────────────
# Controls the `live-mcp` mode. All three are optional; unset yields the
# Bloomreach OAuth flow against the alpha endpoint — "Bloomreach as the
# example config out of the box."

# MCP server URL. Falls back to BLOOMREACH_MCP_URL, then to Bloomreach alpha.
# MCP_URL=https://your-mcp-server.example.com/mcp/

# Auth type: oauth-bloomreach | bearer | anonymous
# - oauth-bloomreach: OAuth 2.1 + PKCE + DCR (default). Works against any
#   MCP server supporting the flow.
# - bearer: static bearer token; requires MCP_AUTH_TOKEN. Test only — the
#   token sits in your env in plaintext.
# - anonymous: no Authorization header sent. For local dev MCP servers.
# MCP_AUTH_TYPE=oauth-bloomreach

# Required when MCP_AUTH_TYPE=bearer.
# MCP_AUTH_TOKEN=

# ─── legacy (deprecated, still honored) ─────────────────────────────────────
# Pre-Session-C name for MCP_URL. Read as fallback so pre-rename deployments
# keep working.
BLOOMREACH_MCP_URL=https://loomi-mcp-alpha.bloomreach.com/mcp/

# ─── project + branding ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="blooming insights"

# The app's own origin — used to build the OAuth redirect URI
# (${APP_ORIGIN}/api/mcp/callback). MUST match the real deployment URL.
#   local:  http://localhost:3000
#   vercel: https://<your-project>.vercel.app
APP_ORIGIN=http://localhost:3000

# Optional: pin the Engagement project the agents analyze. If unset, the
# schema bootstrap navigates list_cloud_organizations -> list_projects and
# picks the single/first project. Bloomreach-specific.
# BLOOMREACH_PROJECT_ID=

# ─── demo lock (optional, preview envs) ─────────────────────────────────────
# When set to '1', hard-locks demo mode + hides the toggle. Used by the Vercel
# preview environment to keep the deploy demo-only. Prefixed with
# NEXT_PUBLIC_ because it's read on the client.
# NEXT_PUBLIC_DEMO_ONLY=1

# ─── budget ceiling (eval runner default) ──────────────────────────────────
# Per-investigation budget in USD, enforced by BudgetTracker's
# check-before-dispatch. Currently threaded through the eval runner;
# production route wiring is a separate follow-up.
# BUDGET_MAX_USD=2.0
