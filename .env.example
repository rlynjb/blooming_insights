# Required: the Anthropic key the agents reason with.
ANTHROPIC_API_KEY=

# The Bloomreach loomi connect MCP endpoint.
BLOOMREACH_MCP_URL=https://loomi-mcp-alpha.bloomreach.com/mcp/

NEXT_PUBLIC_APP_NAME="blooming insights"

# The app's own origin, used to build the OAuth redirect URI
# (${APP_ORIGIN}/api/mcp/callback). MUST match the real deployment URL.
#   local:  http://localhost:3000
#   vercel: https://<your-project>.vercel.app
APP_ORIGIN=http://localhost:3000

# Required IN PRODUCTION ONLY: a strong random secret (>= 32 chars) used to
# AES-256-GCM encrypt the httpOnly auth cookie that carries OAuth state + tokens
# across Vercel's stateless function instances. Generate with:
#   openssl rand -base64 32
# Not needed locally — dev persists auth to a gitignored .auth-cache.json file.
AUTH_SECRET=

# Optional: pin the Engagement project the agents analyze. If unset, the schema
# bootstrap navigates list_cloud_organizations -> list_projects and picks the
# single/first project. For the wobbly-ukulele sandbox:
# BLOOMREACH_PROJECT_ID=b639d584-5469-11f1-bda3-4eec909e5c19
